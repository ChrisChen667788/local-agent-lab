{
  "name": "local-agent-lab",
  "version": "0.3.1",
  "private": true,
  "description": "First LLM Studio: local-first LLM workbench for Apple Silicon with MLX runtimes, Compare Lab, benchmark ops, and remote model comparisons.",
  "license": "MIT",
  "homepage": "https://github.com/ChrisChen667788/local-agent-lab",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChrisChen667788/local-agent-lab.git"
  },
  "bugs": {
    "url": "https://github.com/ChrisChen667788/local-agent-lab/issues"
  },
  "keywords": [
    "agent",
    "benchmark",
    "mlx",
    "apple-silicon",
    "nextjs",
    "llm",
    "qwen",
    "coding-agent",
    "observability"
  ],
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "./scripts/run-next.sh dev 3011",
    "build": "./scripts/run-next.sh build",
    "start": "./scripts/run-next.sh start 3011",
    "lint": "./scripts/run-lint.sh",
    "typecheck": "./scripts/run-typecheck.sh full",
    "typecheck:partitions": "./scripts/run-typecheck.sh partitions",
    "typecheck:changed": "./scripts/run-typecheck.sh changed",
    "smoke:routes": "./scripts/route-smoke.sh",
    "smoke:screenshots": "./scripts/screenshot-smoke.sh",
    "typecheck:validate": "./scripts/run-typecheck.sh validate",
    "typecheck:changed:dry": "TYPECHECK_DRY_RUN=1 ./scripts/run-typecheck.sh changed",
    "typecheck:core": "./scripts/run-typecheck.sh core",
    "typecheck:agent": "./scripts/run-typecheck.sh agent",
    "typecheck:admin": "./scripts/run-typecheck.sh admin",
    "typecheck:app": "./scripts/run-typecheck.sh app"
  },
  "dependencies": {
    "next": "14.2.33",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.33",
    "playwright": "^1.54.1",
    "postcss": "8.4.40",
    "tailwindcss": "3.4.9",
    "typescript": "5.5.4"
  }
}
