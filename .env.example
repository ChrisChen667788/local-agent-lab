# Local MLX gateway
LOCAL_AGENT_BASE_URL=http://127.0.0.1:4000/v1
LOCAL_QWEN_0_6B_MODEL=local-qwen3-0.6b
LOCAL_QWEN_4B_4BIT_MODEL=local-qwen3-4b-4bit
LOCAL_QWEN35_4B_4BIT_MODEL=local-qwen35-4b-4bit
LOCAL_QWEN_0_6B_REPO=Qwen/Qwen3-0.6B-MLX-6bit
LOCAL_QWEN_4B_4BIT_REPO=mlx-community/Qwen3-4B-Instruct-2507-4bit
LOCAL_QWEN35_4B_4BIT_REPO=mlx-community/Qwen3.5-4B-4bit

# OpenAI / Codex
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2-codex
OPENAI_THINKING_MODEL=gpt-5.2-codex

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://vip.aipro.love
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_THINKING_MODEL=claude-sonnet-4-6

# Moonshot / Kimi
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2-0905-preview
KIMI_THINKING_MODEL=kimi-k2-0905-preview

# Zhipu / GLM
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7
GLM_THINKING_MODEL=glm-4.7

# Qwen / DashScope
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_THINKING_MODEL=qwen-plus
